# =============================================================================
# DataVault — .env.local (git-ignored)
# =============================================================================
# Secrets and local overrides. Copy this file to .env.local and fill in values.
# .env.local is never committed — keep all secrets here.
# =============================================================================


# ── Aptos node (optional override) ────────────────────────────────────────────

# Uncomment to use a staging or private node instead of the public default.
# NEXT_PUBLIC_APTOS_NODE_URL=https://api.testnet.staging.aptoslabs.com/v1


# ── Aptos API key ──────────────────────────────────────────────────────────────

# Aptos Labs API key for higher rate limits on the Aptos node.
# Get from: https://build.aptoslabs.com → create project → API key
NEXT_PUBLIC_APTOS_API_KEY=aptoslabs_...


# ── Deployed contract ──────────────────────────────────────────────────────────

# Address of the deployed Move module. Written automatically by npm run move:publish.
NEXT_PUBLIC_MODULE_ADDRESS=0x...


# ── Deployer account (Aptos CLI only) ─────────────────────────────────────────

# Used by: npm run move:publish / move:upgrade
# Must hold APT on the target network for gas.
# Get your address: aptos config show-profiles  OR check your wallet.
NEXT_MODULE_PUBLISHER_ACCOUNT_ADDRESS=0x...
NEXT_MODULE_PUBLISHER_ACCOUNT_PRIVATE_KEY=ed25519-priv-0x...


# ── Shelby blob storage ────────────────────────────────────────────────────────

# Geomi API key — used server-side to sign and proxy Shelby blob operations.
# Get from: https://geomi.dev → create project → API Resource → copy key
SHELBY_API_KEY=AG-...

# Same key exposed to the browser for client-side putBlob calls.
# Required by Next.js — only NEXT_PUBLIC_ vars are available in the browser bundle.
NEXT_PUBLIC_SHELBY_API_KEY=AG-...

# Origin header sent with server-side Shelby requests.
# Must match the domain your server runs on. Defaults to http://localhost:3000.
NEXT_PUBLIC_APP_URL=http://localhost:3000
